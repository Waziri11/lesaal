# Database
DATABASE_URL="postgresql://postgres:password@db.prisma.io:5432/postgres?sslmode=verify-full"

# Initial admin bootstrap (used by npm run seed:admin)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="set-a-strong-password"

# Security
CSRF_SECRET="set-a-long-random-secret"
CRON_SECRET="set-a-long-random-cron-secret"
TURNSTILE_SECRET_KEY="cloudflare-turnstile-secret-key"
TURNSTILE_SITE_KEY="cloudflare-turnstile-site-key"

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES="15"
RATE_LIMIT_MAX_LOGIN_IP="10"
RATE_LIMIT_MAX_LOGIN_EMAIL="5"
RATE_LIMIT_MAX_PUBLIC_IP="30"
RATE_LIMIT_MAX_PUBLIC_CAMPAIGN_IP="10"
RATE_LIMIT_MAX_OTP_REQUESTS="3"

# SMTP (Gmail app password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-gmail-address@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="Lesaal Admin <your-gmail-address@gmail.com>"

# Notification recipient for campaign form submissions
NOTIFY_EMAIL="leilawaziri@lesaal.com"
