# Database
DATABASE_URL="postgresql://postgres:password@db.prisma.io:5432/postgres?sslmode=verify-full"

# Initial admin bootstrap (used by npm run seed:admin)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="set-a-strong-password"

# Security
CSRF_SECRET="set-a-long-random-secret"
CRON_SECRET="set-a-long-random-cron-secret"
TURNSTILE_SECRET_KEY="cloudflare-turnstile-secret-key"
TURNSTILE_SITE_KEY="cloudflare-turnstile-site-key"
TRUST_PROXY_HEADERS="false"

# Google Drive project repository integration
GOOGLE_OAUTH_CLIENT_ID="google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="google-oauth-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/admin/integrations/google-drive/callback"
GOOGLE_DRIVE_DEVELOPER_KEY="google-browser-api-key"
GOOGLE_DRIVE_APP_ID="google-cloud-project-number"
GOOGLE_DRIVE_TOKEN_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES="15"
RATE_LIMIT_MAX_LOGIN_IP="10"
RATE_LIMIT_MAX_LOGIN_EMAIL="5"
RATE_LIMIT_MAX_PUBLIC_IP="30"
RATE_LIMIT_MAX_PUBLIC_CAMPAIGN_IP="10"
RATE_LIMIT_MAX_OTP_REQUESTS="3"
CSV_EXPORT_MAX_ROWS="10000"
BULK_RESPOND_CONCURRENCY="5"
BULK_RESPOND_MAX_RECIPIENTS="2000"

# SMTP (Gmail app password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-gmail-address@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="Lesaal Marketing <your-gmail-address@gmail.com>"

# Notification recipient for campaign form submissions
NOTIFY_EMAIL="leilawaziri@lesaal.com"
