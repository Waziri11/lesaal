generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator client_js {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SectionType {
  HERO
  STATS_BAND
  CLIENT_LOGOS
  SERVICES_GRID
  COMMENTARY
  PRICING
  FAQ
  FOOTER
  // Legacy section types retained for safe migration/reads.
  SERVICES
  CLIENTS_TESTIMONY
  CAMPAIGN_FORM
  CARDS
  LIST
  TABLE
  RICH_TEXT
  CTA
  FORM
}

enum ComponentVariant {
  DEFAULT
  CARD
  LIST
  TABLE
  GRID
}

enum TextAnimationPreset {
  NONE
  FADE_UP
  SLIDE_IN
  ZOOM_IN
  TYPEWRITER
}

enum SectionAnimationPreset {
  NONE
  FADE_IN
  SCALE_IN
  SLIDE_UP
}

enum ScrollAnimationPreset {
  NONE
  PARALLAX
  STICKY
  REVEAL
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  firstName          String?
  lastName           String?
  birthDate          DateTime?
  companyName        String         @default("Lesaal")
  companyDescription String?
  profileImageUrl    String?
  gender             String?
  region             String?
  district           String?
  ward               String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  sessions           AdminSession[]
  otpCodes           EmailOtpCode[]
  mediaAssets        MediaAsset[]
  notes              AdminNote[]
}

model AdminSession {
  id        String    @id @default(cuid())
  adminId   String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
}

model LandingPageConfig {
  id          String              @id @default(cuid())
  siteTitle   String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  sections    LandingSection[]
  formFields  CampaignFormField[]
  submissions CampaignSubmission[]
}

model LandingSection {
  id                String                 @id @default(cuid())
  configId          String
  type              SectionType
  title             String
  isVisible         Boolean                @default(true)
  order             Int
  componentVariant  ComponentVariant       @default(DEFAULT)
  textAnimation     TextAnimationPreset    @default(FADE_UP)
  sectionAnimation  SectionAnimationPreset @default(FADE_IN)
  scrollAnimation   ScrollAnimationPreset  @default(NONE)
  settings          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  config            LandingPageConfig      @relation(fields: [configId], references: [id], onDelete: Cascade)
  items             SectionItem[]

  @@index([configId])
  @@index([order])
}

model SectionItem {
  id          String         @id @default(cuid())
  sectionId   String
  order       Int
  label       String?
  title       String?
  description String?
  imageUrl    String?
  value       String?
  extra       Json?
  section     LandingSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([order])
}

model CampaignFormField {
  id          String            @id @default(cuid())
  configId    String
  key         String
  label       String
  type        String
  required    Boolean           @default(false)
  placeholder String?
  options     Json?
  order       Int
  isVisible   Boolean           @default(true)
  config      LandingPageConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([order])
}

model CampaignSubmission {
  id          String            @id @default(cuid())
  configId    String
  data        Json
  submittedAt DateTime          @default(now())
  config      LandingPageConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([submittedAt])
}

model Campaign {
  id          String             @id @default(cuid())
  title       String
  slug        String             @unique
  targetMarket String
  deadline    DateTime?
  description String
  imageUrl    String?
  isPublished Boolean            @default(true)
  order       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  questions   CampaignQuestion[]
  responses   CampaignResponse[]
  notifications AdminNotification[]

  @@index([order])
  @@index([isPublished])
  @@index([isPublished, deadline, order, createdAt])
}

model CampaignQuestion {
  id          String   @id @default(cuid())
  campaignId  String
  sectionKey  String?
  sectionTitle String?
  sectionDescription String?
  sectionOrder Int      @default(0)
  key         String
  label       String
  type        String
  required    Boolean  @default(false)
  placeholder String?
  options     Json?
  order       Int
  isVisible   Boolean  @default(true)
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([order])
}

model CampaignResponse {
  id            String              @id @default(cuid())
  campaignId    String
  data          Json
  submittedAt   DateTime            @default(now())
  campaign      Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  notifications AdminNotification[]

  @@index([campaignId])
  @@index([submittedAt])
  @@index([campaignId, submittedAt, id])
}

model AdminNotification {
  id                String           @id @default(cuid())
  type              String
  title             String
  message           String
  isRead            Boolean          @default(false)
  readAt            DateTime?
  payload           Json?
  campaignId        String?
  campaignResponseId String?
  createdAt         DateTime         @default(now())
  campaign          Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignResponse  CampaignResponse? @relation(fields: [campaignResponseId], references: [id], onDelete: SetNull)

  @@index([isRead])
  @@index([createdAt])
  @@index([campaignId])
  @@index([campaignResponseId])
  @@index([isRead, createdAt, id])
}

model EmailOtpCode {
  id          String    @id @default(cuid())
  adminId     String
  email       String
  codeHash    String
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  createdAt   DateTime  @default(now())
  admin       AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([email])
  @@index([expiresAt])
}

model MediaAsset {
  id           String    @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  uploadedById String?
  createdAt    DateTime  @default(now())
  uploadedBy   AdminUser? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([createdAt])
}

model AdminNote {
  id        String    @id @default(cuid())
  adminId   String
  title     String
  content   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([updatedAt])
  @@index([adminId, updatedAt, id])
}

model RateLimitEntry {
  id          String   @id @default(cuid())
  key         String   @unique
  count       Int      @default(0)
  windowStart DateTime
  lockedUntil DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([windowStart])
  @@index([lockedUntil])
}
